{
	"version": 3,
	"configurePresets": [
		{
			"name": "dkp",
			"displayName": "devkitPro",
			"binaryDir": "${sourceDir}/build/dkp",
			"toolchainFile": "$env{DEVKITPRO}/cmake/NDS.cmake",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release",
				"NDS_TOOLCHAIN_VENDOR": "dkp"
			}
		},
		{
			"name": "blocksds",
			"displayName": "BlocksDS",
			"binaryDir": "${sourceDir}/build/blocks",
			"toolchainFile": "$env{BLOCKSDS}/cmake/BlocksDS.cmake",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release",
				"NDS_TOOLCHAIN_VENDOR": "blocks"
			}
		}
	]
}